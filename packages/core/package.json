{
  "name": "@lahin31/debugcontext-core",
  "version": "0.1.0",
  "description": "Zero-configuration debugging context SDK for Node.js — automatically captures request, runtime, system, git, and error context on every thrown error.",
  "keywords": [
    "debugging",
    "error",
    "error-context",
    "incident",
    "nodejs",
    "typescript",
    "sdk",
    "express",
    "zero-config",
    "developer-tools",
    "observability",
    "stack-trace",
    "request-context"
  ],
  "author": {
    "name": "lahin31",
    "url": "https://github.com/lahin31"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lahin31/debugcontext.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/lahin31/debugcontext/issues"
  },
  "homepage": "https://github.com/lahin31/debugcontext#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist coverage"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false
}
