{
  "name": "@lahin31/debugcontext-express",
  "version": "0.1.0",
  "description": "Express.js adapter for DebugContext — automatically captures request context, redacts sensitive data, and structures every route error as a debuggable Incident.",
  "keywords": [
    "debugcontext",
    "express",
    "express-middleware",
    "error-handling",
    "debugging",
    "typescript",
    "nodejs",
    "sdk",
    "incident",
    "zero-config",
    "developer-tools",
    "request-context",
    "error-middleware"
  ],
  "author": {
    "name": "lahin31",
    "url": "https://github.com/lahin31"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lahin31/debugcontext.git",
    "directory": "packages/express"
  },
  "bugs": {
    "url": "https://github.com/lahin31/debugcontext/issues"
  },
  "homepage": "https://github.com/lahin31/debugcontext#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@lahin31/debugcontext-core": "^0.1.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "express": "^4.18.0",
    "supertest": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false
}
