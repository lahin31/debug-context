{
  "name": "@debugcontext/express",
  "version": "0.1.0",
  "description": "Express.js adapter for DebugContext — automatic error capture middleware",
  "keywords": [
    "debugcontext",
    "express",
    "middleware",
    "error-handling",
    "debugging",
    "typescript"
  ],
  "author": "DebugContext Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/debugcontext/debugcontext",
    "directory": "packages/express"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@debugcontext/core": "*"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "express": "^4.18.0",
    "supertest": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false
}
